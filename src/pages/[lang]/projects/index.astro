---
/**
 * src/pages/[lang]/projects/index.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Página de listado de todos los proyectos del idioma.
 */
import MainLayout    from '@/layouts/MainLayout.astro';
import ProjectCard   from '@/components/projects/ProjectCard.astro';
import { useTranslations, SUPPORTED_LANGS, type Lang } from '@/utils/i18n';
import { getProjectsByLang, getBio } from '@/utils/content';

export async function getStaticPaths() {
  return SUPPORTED_LANGS.map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params as { lang: Lang };
const t        = useTranslations(lang);
const projects = await getProjectsByLang(lang);
const bio      = await getBio(lang);
---

<MainLayout
  title={t('projects.title')}
  description={t('projects.subtitle')}
  lang={lang}
>
  <section
    class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8"
    aria-labelledby="projects-heading"
  >
    <div class="mb-12">
      <a
        href={`${import.meta.env.BASE_URL}${lang}/`}
        class="mb-6 inline-flex items-center gap-1 text-sm text-[var(--text-muted)] hover:text-[var(--accent)] transition-colors"
      >
        ← {lang === 'es' ? 'Inicio' : 'Home'}
      </a>
      <h1
        id="projects-heading"
        class="text-3xl font-bold tracking-tight text-[var(--text)] sm:text-4xl"
      >
        {t('projects.title')}
      </h1>
      <p class="mt-3 text-[var(--text-muted)]">
        {t('projects.subtitle')}
      </p>
    </div>

    {projects.length === 0 ? (
      <p class="text-center text-[var(--text-muted)]">
        {lang === 'es' ? 'No hay proyectos disponibles.' : 'No projects available.'}
      </p>
    ) : (
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {projects.map((project) => (
          <ProjectCard project={project} lang={lang} />
        ))}
      </div>
    )}
  </section>
</MainLayout>
