---
/**
 * ProjectCard.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Tarjeta de proyecto con carrusel de imágenes, logos de herramientas y links.
 */
import ImageCarousel from '@/components/projects/ImageCarousel.astro';
import type { Lang } from '@/utils/i18n';
import { useTranslations } from '@/utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  lang:    Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, image, images, stack, links, featured } = project.data;

// ID único para el carrusel basado en el slug del proyecto
const carouselId = project.id.replace(/[^a-z0-9]/gi, '-');

// Galería: si hay imágenes adicionales las usamos, si no usamos la imagen principal
const galleryImages = (images && images.length > 0) ? images : [image];

// ─── Mapa de logos de herramientas ───────────────────────────────────────────
// Devuelve una URL de logo desde Simple Icons CDN u otras fuentes confiables
function getToolLogo(tech: string): { src: string; label: string } | null {
  const map: Record<string, string> = {
    // Herramientas del proyecto
    'n8n':           'https://avatars.githubusercontent.com/u/45487711?s=48&v=4',
    'chatwoot':      'https://avatars.githubusercontent.com/u/55601651?s=48&v=4',
    'evolution api': 'https://avatars.githubusercontent.com/u/121045016?s=48&v=4',
    'evolution':     'https://avatars.githubusercontent.com/u/121045016?s=48&v=4',
    'postgresql':    'https://cdn.simpleicons.org/postgresql/4169E1',
    'chatgpt':       'https://cdn.simpleicons.org/openai/10a37f',
    'openai':        'https://cdn.simpleicons.org/openai/10a37f',
    'deepseek':      'https://cdn.simpleicons.org/deepseek/007BFF',
    'flutterflow':   'https://cdn.simpleicons.org/flutter/54C5F8',
    'flutter':       'https://cdn.simpleicons.org/flutter/54C5F8',
    'api rest':      'https://cdn.simpleicons.org/fastapi/009688',
    'dart':          'https://cdn.simpleicons.org/dart/0175C2',
    // Stack genérico
    'node.js':       'https://cdn.simpleicons.org/nodedotjs/339933',
    'typescript':    'https://cdn.simpleicons.org/typescript/3178C6',
    'kubernetes':    'https://cdn.simpleicons.org/kubernetes/326CE5',
    'rabbitmq':      'https://cdn.simpleicons.org/rabbitmq/FF6600',
    'redis':         'https://cdn.simpleicons.org/redis/DC382D',
    'docker':        'https://cdn.simpleicons.org/docker/2496ED',
    'python':        'https://cdn.simpleicons.org/python/3776AB',
    'react':         'https://cdn.simpleicons.org/react/61DAFB',
    'astro':         'https://cdn.simpleicons.org/astro/FF5D01',
    'fastapi':       'https://cdn.simpleicons.org/fastapi/009688',
    'linux':         'https://cdn.simpleicons.org/linux/FCC624',
    'git':           'https://cdn.simpleicons.org/git/F05032',
    'github':        'https://cdn.simpleicons.org/github/ffffff',
    'sql server':    'https://cdn.simpleicons.org/microsoftsqlserver/CC2927',
    'airtable':      'https://cdn.simpleicons.org/airtable/18BFFF',
    'clickup':       'https://cdn.simpleicons.org/clickup/7B68EE',
  };
  const key = tech.toLowerCase();
  const src = map[key];
  return src ? { src, label: tech } : null;
}

// Determinar si para este stack mostramos logos (si al menos 1 herramienta tiene logo)
const stackWithLogos = stack.filter(t => getToolLogo(t) !== null);
const useLogos = stackWithLogos.length >= 2;
---

<article
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-[var(--accent)]/40 hover:shadow-lg hover:shadow-[var(--accent)]/5"
  aria-label={title}
>
  <!-- Badge featured -->
  {featured && (
    <div class="absolute left-3 top-3 z-10">
      <span class="inline-flex items-center gap-1.5 rounded-full border border-emerald-500/20 bg-emerald-500/10 px-2.5 py-1 text-xs font-medium text-emerald-600 dark:text-emerald-400">
        <span class="h-1.5 w-1.5 rounded-full bg-emerald-500 animate-pulse" aria-hidden="true" />
        {t('projects.featured')}
      </span>
    </div>
  )}

  <!-- Carrusel de imágenes -->
  <ImageCarousel images={galleryImages} title={title} carouselId={carouselId} />

  <!-- Contenido -->
  <div class="flex flex-1 flex-col gap-3 p-5">
    <!-- Título -->
    <h3 class="text-lg font-semibold leading-tight text-[var(--text)]">
      {title}
    </h3>

    <!-- Descripción -->
    <p class="flex-1 text-sm leading-relaxed text-[var(--text-muted)]">
      {description}
    </p>

    <!-- Stack: logos si están disponibles, badges de texto como fallback -->
    <div class="mt-1" aria-label={t('projects.stack')}>
      {useLogos ? (
        <div class="flex flex-wrap items-center gap-2">
          {stack.map((tech) => {
            const logo = getToolLogo(tech);
            return logo ? (
              <div class="group/tool relative flex h-8 w-8 items-center justify-center rounded-lg border border-[var(--border)] bg-[var(--bg-elevated)] p-1 transition-all duration-200 hover:border-[var(--accent)]/50 hover:shadow-md">
                <img
                  src={logo.src}
                  alt={logo.label}
                  width="22"
                  height="22"
                  class="h-5 w-5 object-contain"
                  loading="lazy"
                />
                <!-- Tooltip -->
                <span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded bg-[var(--bg-elevated)] border border-[var(--border)] px-2 py-0.5 text-[10px] font-medium text-[var(--text)] opacity-0 shadow-md transition-opacity duration-150 group-hover/tool:opacity-100 z-30">
                  {logo.label}
                </span>
              </div>
            ) : (
              <span class="inline-flex items-center rounded-md border border-[var(--border)] bg-[var(--bg-elevated)] px-2 py-0.5 text-[10px] font-mono text-[var(--text-muted)]">
                {tech}
              </span>
            );
          })}
        </div>
      ) : (
        <div class="flex flex-wrap gap-1.5">
          {stack.slice(0, 5).map((tech) => (
            <span class="inline-flex items-center rounded-md border border-[var(--border)] bg-[var(--bg-elevated)] px-2.5 py-0.5 text-xs font-medium font-mono tracking-wide text-[var(--text-muted)]">
              {tech}
            </span>
          ))}
          {stack.length > 5 && (
            <span class="inline-flex items-center rounded-md border border-[var(--border)] bg-[var(--bg-elevated)] px-2.5 py-0.5 text-xs font-medium font-mono tracking-wide text-[var(--text-muted)]">
              +{stack.length - 5}
            </span>
          )}
        </div>
      )}
    </div>

    <!-- Links -->
    {(links.demo || links.github) && (
      <div class="mt-2 flex items-center justify-end border-t border-[var(--border)] pt-4">
        <div class="flex items-center gap-3">
          {links.demo && (
            <a
              href={links.demo}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-[var(--text-muted)] transition-colors hover:text-[var(--text)]"
              aria-label={`${t('projects.demo')} de ${title}`}
            >
              {t('projects.demo')} ↗
            </a>
          )}
          {links.github && (
            <a
              href={links.github}
              target="_blank"
              rel="noopener noreferrer"
              class="text-xs text-[var(--text-muted)] transition-colors hover:text-[var(--text)]"
              aria-label={`${t('projects.code')} de ${title}`}
            >
              {t('projects.code')} ↗
            </a>
          )}
        </div>
      </div>
    )}
  </div>
</article>
