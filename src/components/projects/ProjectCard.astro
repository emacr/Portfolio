---
/**
 * ProjectCard.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Tarjeta de proyecto con imagen optimizada, stack badges y links.
 * Usa <Image /> de Astro para garantizar WebP + múltiples tamaños.
 */
import { Image }  from 'astro:assets';
import Badge       from '@/components/ui/Badge.astro';
import type { Lang } from '@/utils/i18n';
import { useTranslations } from '@/utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  lang:    Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);
const { title, description, image, stack, links, featured } = project.data;
---

<article
  class="group relative flex flex-col overflow-hidden rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-[var(--accent)]/40 hover:shadow-lg hover:shadow-[var(--accent)]/5"
  aria-label={title}
>
  <!-- Badge featured -->
  {featured && (
    <div class="absolute left-3 top-3 z-10">
      <Badge label={t('projects.featured')} variant="accent" />
    </div>
  )}

  <!-- Imagen del proyecto -->
  <div
    class="block overflow-hidden"
    tabindex="-1"
    aria-hidden="true"
  >
    <Image
      src={image}
      alt={`Diagrama o captura del proyecto ${title}`}
      width={720}
      height={405}
      format="webp"
      quality={85}
      class="h-48 w-full object-cover transition-transform duration-500 group-hover:scale-105"
      loading="lazy"
    />
  </div>

  <!-- Contenido -->
  <div class="flex flex-1 flex-col gap-3 p-5">
    <!-- Título -->
    <h3 class="text-lg font-semibold leading-tight text-[var(--text)]">
      {title}
    </h3>

    <!-- Descripción -->
    <p class="flex-1 text-sm leading-relaxed text-[var(--text-muted)]">
      {description}
    </p>

    <!-- Stack -->
    <div class="flex flex-wrap gap-1.5" aria-label={t('projects.stack')}>
      {stack.slice(0, 5).map((tech) => (
        <Badge label={tech} variant="default" />
      ))}
      {stack.length > 5 && (
        <Badge label={`+${stack.length - 5}`} variant="default" />
      )}
    </div>

    <!-- Links -->
    <div class="mt-2 flex items-center justify-end border-t border-[var(--border)] pt-4">
      <div class="flex items-center gap-3">
        {links.demo && (
          <a
            href={links.demo}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-[var(--text-muted)] transition-colors hover:text-[var(--text)]"
            aria-label={`${t('projects.demo')} de ${title}`}
          >
            {t('projects.demo')} ↗
          </a>
        )}
        {links.github && (
          <a
            href={links.github}
            target="_blank"
            rel="noopener noreferrer"
            class="text-xs text-[var(--text-muted)] transition-colors hover:text-[var(--text)]"
            aria-label={`${t('projects.code')} de ${title}`}
          >
            {t('projects.code')} ↗
          </a>
        )}
      </div>
    </div>
  </div>
</article>
