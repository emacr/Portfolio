---
/**
 * CaseStudyDetail.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Layout de detalle de Case Study. Incluye:
 *   - Diagrama de arquitectura (imagen estática optimizada)
 *   - Requerimientos No Funcionales (NFRs)
 *   - Architecture Decision Records (ADRs) en acordeón HTML nativo
 *
 * El acordeón usa <details>/<summary> — Zero JS, accesible nativamente.
 */
import { Image }   from 'astro:assets';
import Badge        from '@/components/ui/Badge.astro';
import type { Lang } from '@/utils/i18n';
import { useTranslations } from '@/utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  lang:    Lang;
}

const { project, lang } = Astro.props;
const t = useTranslations(lang);

const {
  title,
  description,
  date,
  stack,
  links,
  nfr,
  adrs,
  image,
} = project.data;

---

<div class="mx-auto max-w-4xl px-4 py-12 sm:px-6 lg:px-8">

  <!-- Encabezado del proyecto -->
  <header class="mb-10">
    <div class="mb-4 flex flex-wrap gap-2">
      {stack.map((tech) => <Badge label={tech} variant="subtle" />)}
    </div>
    <h1 class="text-3xl font-bold tracking-tight text-[var(--text)] sm:text-4xl">
      {title}
    </h1>
    <p class="mt-3 text-lg text-[var(--text-muted)]">{description}</p>
    <time
      datetime={date.toISOString()}
      class="mt-2 block text-sm text-[var(--text-muted)]"
    >
      {date.toLocaleDateString(lang === 'es' ? 'es-MX' : 'en-US', { year: 'numeric', month: 'long' })}
    </time>

    <!-- Links de proyecto -->
    <div class="mt-5 flex gap-4">
      {links.demo && (
        <a
          href={links.demo}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--border)] px-4 py-2 text-sm font-medium text-[var(--text)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
        >
          {t('projects.demo')} ↗
        </a>
      )}
      {links.github && (
        <a
          href={links.github}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-lg border border-[var(--border)] px-4 py-2 text-sm font-medium text-[var(--text)] transition-colors hover:border-[var(--accent)] hover:text-[var(--accent)]"
        >
          {t('projects.code')} ↗
        </a>
      )}
    </div>
  </header>

  <!-- ─── Diagrama de Arquitectura ─────────────────────────────────────────── -->
  <section class="mb-12" aria-labelledby="arch-heading">
    <h2
      id="arch-heading"
      class="mb-4 text-xl font-semibold text-[var(--text)]"
    >
      {t('projects.architecture')}
    </h2>
    <div class="overflow-hidden rounded-xl border border-[var(--border)]">
      <Image
        src={image}
        alt={`Diagrama de arquitectura del proyecto ${title}`}
        width={1200}
        height={675}
        format="webp"
        quality={90}
        class="w-full"
        loading="eager"
      />
    </div>
  </section>

  <!-- ─── Contenido MDX ─────────────────────────────────────────────────────── -->
  <section class="prose mb-12 max-w-none">
    <slot />
  </section>

  <!-- ─── Requerimientos No Funcionales (NFRs) ─────────────────────────────── -->
  {nfr && nfr.length > 0 && (
    <section class="mb-12" aria-labelledby="nfr-heading">
      <h2
        id="nfr-heading"
        class="mb-4 text-xl font-semibold text-[var(--text)]"
      >
        {t('projects.nfr')}
      </h2>
      <ul class="space-y-2.5 rounded-xl border border-[var(--border)] bg-[var(--bg-card)] p-6">
        {nfr.map((req) => (
          <li class="flex items-start gap-3 text-sm text-[var(--text-muted)]">
            <span class="mt-1 h-1.5 w-1.5 shrink-0 rounded-full bg-[var(--accent)]" aria-hidden="true" />
            <span>{req}</span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <!-- ─── Architecture Decision Records (ADRs) ─────────────────────────────── -->
  <!--
    DISEÑO: Se usa el elemento nativo <details>/<summary> para el acordeón.
    Ventajas: Zero JS, accesible por defecto (teclado + screen readers),
    semánticamente correcto para contenido expandible.
  -->
  {adrs && adrs.length > 0 && (
    <section class="mb-12" aria-labelledby="adrs-heading">
      <h2
        id="adrs-heading"
        class="mb-4 text-xl font-semibold text-[var(--text)]"
      >
        {t('projects.adrs')}
      </h2>
      <div class="space-y-3">
        {adrs.map((adr, i) => (
          <details
            class="group rounded-xl border border-[var(--border)] bg-[var(--bg-card)] transition-colors open:border-[var(--accent)]/40"
          >
            <summary
              class="flex cursor-pointer select-none items-center justify-between gap-4 px-5 py-4 text-sm font-semibold text-[var(--text)] marker:hidden list-none"
            >
              <span>
                <span class="mr-2 font-mono text-[var(--accent)] text-xs">
                  ADR-{String(i + 1).padStart(3, '0')}
                </span>
                {adr.title}
              </span>
              <!-- Chevron animado con CSS -->
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16" height="16"
                viewBox="0 0 24 24"
                fill="none" stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0 text-[var(--text-muted)] transition-transform duration-200 group-open:rotate-180"
                aria-hidden="true"
              >
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="border-t border-[var(--border)] px-5 py-4 space-y-4 text-sm">
              <!-- Contexto -->
              <div>
                <h3 class="mb-1 text-xs font-semibold uppercase tracking-wider text-[var(--accent)]">
                  {t('projects.adr_context')}
                </h3>
                <p class="text-[var(--text-muted)] leading-relaxed">{adr.context}</p>
              </div>
              <!-- Decisión -->
              <div>
                <h3 class="mb-1 text-xs font-semibold uppercase tracking-wider text-[var(--accent)]">
                  {t('projects.adr_decision')}
                </h3>
                <p class="text-[var(--text-muted)] leading-relaxed">{adr.decision}</p>
              </div>
              <!-- Consecuencias -->
              <div>
                <h3 class="mb-1 text-xs font-semibold uppercase tracking-wider text-[var(--accent)]">
                  {t('projects.adr_consequences')}
                </h3>
                <p class="text-[var(--text-muted)] leading-relaxed">{adr.consequences}</p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </section>
  )}
</div>
