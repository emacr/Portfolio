---
/**
 * SkillsGrid.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Grid de tecnologías del stack. Animación de entrada escalonada con CSS.
 */
import type { Lang } from '@/utils/i18n';
import { useTranslations } from '@/utils/i18n';

interface Props {
  lang:   Lang;
  skills: string[];
}

const { lang, skills } = Astro.props;
const t = useTranslations(lang);

const skillIcons: Record<string, string> = {
  "n8n": "https://api.iconify.design/simple-icons/n8n.svg?color=%23EA4335",
  "React": "https://api.iconify.design/logos/react.svg",
  "Astro": "https://api.iconify.design/logos/astro-icon.svg",
  "Python": "https://api.iconify.design/logos/python.svg",
  "FastAPI": "https://api.iconify.design/devicon/fastapi.svg",
  "VirtualBox": "https://api.iconify.design/simple-icons/virtualbox.svg?color=%23183A61",
  "Linux": "https://api.iconify.design/logos/linux-tux.svg",
  "Git": "https://api.iconify.design/logos/git-icon.svg",
  "GitHub": "https://api.iconify.design/mdi/github.svg?color=white",
  "SQL Server": "https://api.iconify.design/simple-icons/microsoftsqlserver.svg?color=%23CC2927",
  "PostgreSQL": "https://api.iconify.design/logos/postgresql.svg",
  "Airtable": "https://api.iconify.design/logos/airtable.svg",
  "FlutterFlow": "https://api.iconify.design/logos/flutter.svg",
  "ClickUp": "https://api.iconify.design/simple-icons/clickup.svg?color=%237B68EE",
  "Chatwoot": "https://api.iconify.design/simple-icons/chatwoot.svg?color=%231F93FF"
};
---

<section
  class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:px-8"
  aria-labelledby="skills-heading"
>
  <!-- Encabezado -->
  <div class="mb-10 text-center">
    <h2
      id="skills-heading"
      class="text-2xl font-bold tracking-tight text-[var(--text)] sm:text-3xl"
    >
      {t('skills.title')}
    </h2>
    <p class="mt-2 text-sm text-[var(--text-muted)]">
      {t('skills.subtitle')}
    </p>
  </div>

  <!-- Grid con animación stagger -->
  <ul
    class="stagger-children grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6 justify-center max-w-4xl mx-auto"
    role="list"
    aria-label={t('skills.title')}
  >
    {skills.map((skill) => (
      <li class="animate-fade-in-up flex flex-col items-center justify-center p-6 rounded-xl hover:bg-[var(--bg-muted)] transition-colors gap-4 group">
        {skillIcons[skill] && (
          <img 
            src={skillIcons[skill]} 
            alt={`${skill} icon`} 
            class="w-14 h-14 object-contain group-hover:scale-110 transition-transform duration-300 drop-shadow-md"
            loading="lazy" 
            width="56" 
            height="56" 
            decoding="async"
          />
        )}
        <span class="text-sm font-medium text-[var(--text-muted)] group-hover:text-[var(--text)] transition-colors">{skill}</span>
      </li>
    ))}
  </ul>
</section>
