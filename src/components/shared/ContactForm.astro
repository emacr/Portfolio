---
/**
 * ContactForm.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Formulario de contacto integrado con Formspree.
 * Estados: default → enviando → éxito | error.
 * El script inline maneja el submit async con fetch; mínimo JS.
 */
import type { Lang } from '@/utils/i18n';
import { useTranslations } from '@/utils/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

// ─── Endpoint de Formspree ────────────────────────────────────────────────────
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/xdayewln';
---

<section
  id="contact"
  class="mx-auto max-w-6xl px-4 py-20 sm:px-6 lg:px-8"
  aria-labelledby="contact-heading"
>
  <div class="mx-auto max-w-2xl">
    <!-- Encabezado -->
    <div class="mb-10 text-center">
      <h2
        id="contact-heading"
        class="text-3xl font-bold tracking-tight text-[var(--text)]"
      >
        {t('contact.title')}
      </h2>
      <p class="mt-2 text-[var(--text-muted)]">
        {t('contact.subtitle')}
      </p>
    </div>

    <!-- Formulario -->
    <form
      id="contact-form"
      action={FORMSPREE_ENDPOINT}
      method="POST"
      novalidate
      class="space-y-5 rounded-2xl border border-[var(--border)] bg-[var(--bg-card)] p-6 shadow-sm sm:p-8"
    >
      <!-- Nombre -->
      <div>
        <label for="contact-name" class="mb-1.5 block text-sm font-medium text-[var(--text)]">
          {t('contact.name')} <span aria-hidden="true" class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="contact-name"
          name="name"
          required
          autocomplete="name"
          placeholder={t('contact.placeholder_name')}
          class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg-elevated)] px-4 py-2.5 text-sm text-[var(--text)] placeholder:text-[var(--text-muted)]/60 outline-none transition-colors focus:border-[var(--accent)] focus:ring-1 focus:ring-[var(--accent)]"
        />
      </div>

      <!-- Email -->
      <div>
        <label for="contact-email" class="mb-1.5 block text-sm font-medium text-[var(--text)]">
          {t('contact.email')} <span aria-hidden="true" class="text-red-500">*</span>
        </label>
        <input
          type="email"
          id="contact-email"
          name="email"
          required
          autocomplete="email"
          placeholder={t('contact.placeholder_email')}
          class="w-full rounded-lg border border-[var(--border)] bg-[var(--bg-elevated)] px-4 py-2.5 text-sm text-[var(--text)] placeholder:text-[var(--text-muted)]/60 outline-none transition-colors focus:border-[var(--accent)] focus:ring-1 focus:ring-[var(--accent)]"
        />
      </div>

      <!-- Mensaje -->
      <div>
        <label for="contact-message" class="mb-1.5 block text-sm font-medium text-[var(--text)]">
          {t('contact.message')} <span aria-hidden="true" class="text-red-500">*</span>
        </label>
        <textarea
          id="contact-message"
          name="message"
          required
          rows="5"
          placeholder={t('contact.placeholder_message')}
          class="w-full resize-none rounded-lg border border-[var(--border)] bg-[var(--bg-elevated)] px-4 py-2.5 text-sm text-[var(--text)] placeholder:text-[var(--text-muted)]/60 outline-none transition-colors focus:border-[var(--accent)] focus:ring-1 focus:ring-[var(--accent)]"
        />
      </div>

      <!-- Submit -->
      <button
        type="submit"
        id="contact-submit"
        class="w-full rounded-lg bg-[var(--accent)] px-6 py-3 text-sm font-semibold text-white shadow-md shadow-[var(--accent)]/20 transition-all duration-200 hover:bg-[var(--accent-hover)] hover:shadow-lg disabled:cursor-not-allowed disabled:opacity-50"
      >
        {t('contact.send')}
      </button>

      <!-- Estados de feedback (ocultos por defecto) -->
      <div
        id="contact-success"
        role="status"
        aria-live="polite"
        class="hidden rounded-lg border border-emerald-500/20 bg-emerald-500/10 px-4 py-3 text-sm font-medium text-emerald-700 dark:text-emerald-400"
      >
        ✓ {t('contact.success')}
      </div>
      <div
        id="contact-error"
        role="alert"
        aria-live="assertive"
        class="hidden rounded-lg border border-red-500/20 bg-red-500/10 px-4 py-3 text-sm font-medium text-red-700 dark:text-red-400"
      >
        ✕ {t('contact.error')}
      </div>
    </form>
  </div>
</section>

<script is:inline>
  // ─── Contact Form Handler ─────────────────────────────────────────────────
  // Script inline autocontenido; no añade nada al bundle de Astro.
  (function () {
    const form    = document.getElementById('contact-form');
    const submit  = document.getElementById('contact-submit');
    const success = document.getElementById('contact-success');
    const error   = document.getElementById('contact-error');

    if (!form || !submit || !success || !error) return;

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      // Estado: enviando
      submit.disabled = true;
      const originalText = submit.textContent;
      submit.textContent = submit.getAttribute('data-sending') || 'Enviando...';
      success.classList.add('hidden');
      error.classList.add('hidden');

      try {
        const data = new FormData(form);
        const res  = await fetch(form.action, {
          method:  'POST',
          body:    data,
          headers: { Accept: 'application/json' },
        });

        if (res.ok) {
          // Estado: éxito
          form.reset();
          success.classList.remove('hidden');
        } else {
          throw new Error('Server error');
        }
      } catch (_) {
        // Estado: error
        error.classList.remove('hidden');
      } finally {
        submit.disabled    = false;
        submit.textContent = originalText;
      }
    });
  })();
</script>
