---
/**
 * Navbar.astro
 * ─────────────────────────────────────────────────────────────────────────────
 * Navegación sticky con efecto glassmorphism (backdrop-blur).
 * Implementado con HTML/CSS puro — Zero JS adicional.
 */
import ThemeToggle      from '@/components/ui/ThemeToggle.astro';
import LanguageSelector from '@/components/ui/LanguageSelector.astro';
import type { Lang }    from '@/utils/i18n';
import { useTranslations } from '@/utils/i18n';

interface Props {
  lang:        Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);

const navLinks = [
  { href: `/${lang}/`,         label: t('nav.home'),     key: 'home' },
  { href: `/${lang}/projects`, label: t('nav.projects'), key: 'projects' },
  { href: `/${lang}/#contact`, label: t('nav.contact'),  key: 'contact' },
];

function isActive(href: string): boolean {
  if (href.includes('#')) return false;
  const normalizedHref = href.replace(/\/$/, '');
  const normalizedPath = currentPath.replace(/\/$/, '');
  return normalizedPath === normalizedHref || normalizedPath.startsWith(normalizedHref + '/');
}
---

<header
  class="sticky top-0 z-50 w-full border-b border-[var(--border)]/60 bg-[var(--bg)]/80 backdrop-blur-md backdrop-saturate-150"
  role="banner"
>
  <nav
    class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6 lg:px-8"
    aria-label="Navegación principal"
  >
    <!-- Logo / Nombre -->
    <a
      href={`/${lang}/`}
      class="flex items-center gap-2 font-semibold tracking-tight text-[var(--text)] transition-opacity hover:opacity-80"
      aria-label="Ir al inicio"
    >
      <span class="text-[var(--accent)] text-xl font-bold">⬡</span>
      <span class="text-sm sm:text-base">Emacr</span>
    </a>

    <!-- Links de navegación (desktop) -->
    <ul
      class="hidden items-center gap-1 md:flex"
      role="list"
    >
      {navLinks.map(({ href, label, key }) => (
        <li>
          <a
            href={href}
            id={`nav-${key}`}
            aria-current={isActive(href) ? 'page' : undefined}
            class={`relative px-3 py-1.5 text-sm font-medium rounded-md transition-colors duration-200
              ${isActive(href)
                ? 'text-[var(--accent)]'
                : 'text-[var(--text-muted)] hover:text-[var(--text)]'
              }`}
          >
            {label}
            {isActive(href) && (
              <span
                class="absolute bottom-0 left-1/2 h-0.5 w-4 -translate-x-1/2 rounded-full bg-[var(--accent)]"
                aria-hidden="true"
              />
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- Controles: idioma, tema, CV -->
    <div class="flex items-center gap-2">
      <LanguageSelector currentLang={lang} />
      <ThemeToggle />
      <a
        href="/cv-emacr.pdf"
        download
        id="btn-download-cv"
        class="hidden items-center gap-1.5 rounded-lg bg-[var(--accent)] px-3 py-1.5 text-sm font-medium text-white transition-all duration-200 hover:bg-[var(--accent-hover)] hover:shadow-md hover:shadow-[var(--accent)]/20 sm:flex"
        aria-label={t('nav.download_cv')}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        CV
      </a>
    </div>
  </nav>
</header>
